# Dependencies
/node_modules/

# Build output
/dist/

# Design tooling
/.impeccable/

# Third-party reference material (large, not part of the app)
/REFERENCE CODE/

# Local working/source asset dirs — served copies live under public/
/outputs/
/photos/

# Unused legacy ascii animations assets
/asciiLegacy

# Docs / notes — kept out of the public repo
*.md

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# Cloudflare local dev
.dev.vars
.wrangler/

# Claude Code local config
.claude/

# Env files — never commit these (site key is public, but keep the habit and
# guard against secrets getting pasted in by mistake)
.env
.env.*
!.env.example
